DATABASE_URL="postgresql://wfh_user:wfh_password@localhost:5432/work_from_hotel?schema=public"
REDIS_URL="redis://localhost:6379"
JWT_SECRET="change_this_to_a_long_random_secret"
JWT_EXPIRES_IN="7d"
PORT=4000
CORS_ORIGIN="http://localhost:5173"

# LinkedIn OAuth (https://www.linkedin.com/developers/apps üzerinden bir uygulama oluşturup
# "Sign In with LinkedIn using OpenID Connect" ürününü ekleyin)
LINKEDIN_CLIENT_ID="your_linkedin_client_id"
LINKEDIN_CLIENT_SECRET="your_linkedin_client_secret"
LINKEDIN_REDIRECT_URI="http://localhost:4000/api/auth/linkedin/callback"

# Firebase Admin SDK — Google ve LinkedIn kimlik jetonlarını doğrular, LinkedIn için
# custom token üretir. Firebase Console > Project Settings > Service accounts >
# "Generate new private key" ile indirilen JSON'daki değerler.
FIREBASE_PROJECT_ID="your_firebase_project_id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@your_project.iam.gserviceaccount.com"
# Private key tek satırda, satır sonları \n olarak, tümü çift tırnak içinde:
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Google Places API (Find Place + Place Details) — https://console.cloud.google.com/apis/credentials
# üzerinden bir API key oluşturup "Places API"yi etkinleştirin. Mekan detaylarını
# (telefon, web sitesi, çalışma saatleri, kategori, doğru isim) zenginleştirmek için
# kullanılır; tanımlı değilse mekan detayları mevcut veritabanı verisiyle çalışmaya
# devam eder (özellik sessizce devre dışı kalır).
GOOGLE_PLACES_API_KEY="your_google_places_api_key"
