generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum PlaceType {
  HOTEL
  CAFE
  LIBRARY
  COWORKING
}

enum Region {
  MURATPASA
  KONYAALTI
  KEPEZ
  LARA
  KALEICI
  DOSEMEALTI
  AKSU
  BELEK
}

enum PlaceStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LevelRating {
  LOW
  MEDIUM
  HIGH
}

enum CommentReportStatus {
  PENDING
  DISMISSED
}

enum NotificationType {
  SUGGESTION_APPROVED
  SUGGESTION_REJECTED
  FAVORITE_PLACE_UPDATED
  COMMENT_REPORTED
  COMMENT_DELETED
  FAVORITE_LOW_OCCUPANCY
  CHAT_REPLY
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String?  @map("password_hash")
  name         String   @map("full_name")
  companyName  String?  @map("company_name")
  role         Role     @default(USER)
  provider     String   @default("local")
  providerId   String?  @map("provider_id")
  avatarUrl    String?  @map("avatar_url")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  places    Place[]
  reviews           Review[]
  favorites         Favorite[]
  occupancyCheckIns OccupancyCheckIn[]
  messages          PlaceMessage[]
  comments            Comment[]
  commentHelpfulVotes CommentHelpfulVote[]
  commentReports      CommentReport[]
  notifications       Notification[]

  @@unique([provider, providerId])
  @@map("users")
}

model Place {
  id              Int         @id @default(autoincrement())
  name            String
  type            PlaceType
  region          Region      @map("district")
  address         String
  lat             Float       @map("latitude")
  lng             Float       @map("longitude")
  description     String?
  priceLevel      Int         @default(2) @map("price_level")
  photoUrls       String[]    @default([]) @map("photo_urls")
  outletLevel     LevelRating @default(MEDIUM) @map("socket_level")
  noiseLevel      LevelRating @default(MEDIUM) @map("quietness_level")
  deskFriendly    Boolean     @default(true) @map("is_desk_friendly")
  openingHours    String?     @map("working_hours")
  openTime        String?     @map("open_time")
  closeTime       String?     @map("close_time")
  hasWifi         Boolean     @default(true) @map("has_wifi")
  hasAC           Boolean     @default(true) @map("has_air_conditioning")
  meetingSuitable Boolean     @default(false) @map("is_meeting_friendly")
  laptopFriendly  Boolean     @default(true) @map("is_laptop_friendly")
  status          PlaceStatus @default(APPROVED)
  createdById     Int?        @map("created_by_id")
  createdBy       User?       @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  reviews           Review[]
  favorites         Favorite[]
  occupancyCheckIns OccupancyCheckIn[]
  messages          PlaceMessage[]
  comments          Comment[]
  notifications     Notification[]

  @@map("places")
}

model Review {
  id               Int      @id @default(autoincrement())
  placeId          Int      @map("place_id")
  place            Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
  userId           Int      @map("user_id")
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  internetSpeed    Int      @map("internet_rating")
  outletCount      Int      @map("socket_rating")
  noiseLevel       Int      @map("quietness_rating")
  coffeeQuality    Int      @map("coffee_rating")
  workEnvironment  Int      @map("work_environment")
  priceLevel       Int      @map("price_level")
  overallRating    Int      @map("rating")
  comment          String?
  createdAt        DateTime @default(now()) @map("created_at")

  @@unique([placeId, userId])
  @@map("reviews")
}

model Favorite {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  placeId   Int      @map("place_id")
  place     Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, placeId])
  @@map("favorites")
}

model OccupancyCheckIn {
  id        Int         @id @default(autoincrement())
  placeId   Int         @map("place_id")
  place     Place       @relation(fields: [placeId], references: [id], onDelete: Cascade)
  userId    Int         @map("user_id")
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  level     LevelRating @map("occupancy_level")
  createdAt DateTime    @default(now()) @map("created_at")

  @@index([placeId, createdAt])
  @@map("occupancy_checkins")
}

model Comment {
  id        Int       @id @default(autoincrement())
  placeId   Int       @map("place_id")
  place     Place     @relation(fields: [placeId], references: [id], onDelete: Cascade)
  userId    Int       @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String
  photoUrl  String?   @map("photo_url")
  isPinned  Boolean   @default(false) @map("is_pinned")
  pinnedAt  DateTime? @map("pinned_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  helpfulVotes CommentHelpfulVote[]
  reports      CommentReport[]

  @@index([placeId, createdAt])
  @@map("comments")
}

model CommentHelpfulVote {
  id        Int      @id @default(autoincrement())
  commentId Int      @map("comment_id")
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  userId    Int      @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([commentId, userId])
  @@map("comment_helpful_votes")
}

model CommentReport {
  id        Int                 @id @default(autoincrement())
  commentId Int                 @map("comment_id")
  comment   Comment             @relation(fields: [commentId], references: [id], onDelete: Cascade)
  userId    Int                 @map("user_id")
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  reason    String?
  status    CommentReportStatus @default(PENDING)
  createdAt DateTime            @default(now()) @map("created_at")

  @@unique([commentId, userId])
  @@map("comment_reports")
}

model Notification {
  id        Int              @id @default(autoincrement())
  userId    Int              @map("user_id")
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  message   String
  placeId   Int?             @map("place_id")
  // Bildirimler her zaman bir mekan bağlamına aittir (sohbet cevabı, favori
  // güncellemesi, öneri sonucu, ...). Mekan silinince o mekana ait bildirim de
  // anlamsız kalır ve linki ölür; bu yüzden SetNull yerine Cascade ile birlikte
  // silinir — böylece "sahipsiz" (placeId'si boşalmış) bildirim oluşmaz.
  place     Place?           @relation(fields: [placeId], references: [id], onDelete: Cascade)
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([userId, type, placeId, createdAt])
  @@map("notifications")
}

model PlaceMessage {
  id        Int      @id @default(autoincrement())
  placeId   Int      @map("place_id")
  place     Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
  userId    Int      @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  @@index([placeId, createdAt])
  @@map("place_messages")
}
