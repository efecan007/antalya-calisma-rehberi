POSTGRES_USER=wfh_user
POSTGRES_PASSWORD=wfh_password
POSTGRES_DB=work_from_hotel
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:8080
REDIS_URL=redis://redis:6379

# LinkedIn OAuth (Firebase custom token köprüsü için backend hâlâ OAuth yürütür)
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_REDIRECT_URI=http://localhost:4000/api/auth/linkedin/callback

# Firebase Admin SDK (backend) — Google/LinkedIn kimlik jetonlarını doğrular
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Firebase Web config (frontend, build-time) — gizli değildir
VITE_FIREBASE_API_KEY=your_web_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
